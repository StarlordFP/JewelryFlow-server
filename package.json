{
  "name": "jewelryflow-backend",
  "version": "0.1.0",
  "description": "JewelryFlow ERP — NestJS API (Trade + Customer modules)",
  "author": "JewelryFlow",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:integration": "jest --config jest-integration.config.ts --runInBand --verbose --forceExit",
    "test:integration:watch": "jest --config jest-integration.config.ts --runInBand --watch",
    "test:integration:cov": "jest --config jest-integration.config.ts --runInBand --coverage --forceExit",
    "test:integration:rates": "jest src/rates/rates.integration.spec.ts --runInBand --verbose",
    "test:integration:stock": "jest src/stock/stock.integration.spec.ts --runInBand --verbose",
    "test:integration:sales": "jest src/sales/sales.integration.spec.ts --runInBand --verbose",
    "test:integration:purchase": "jest src/purchase/purchase.integration.spec.ts --runInBand --verbose",
    "test:integration:karigar": "jest src/karigar/karigar.integration.spec.ts --runInBand --verbose",
    "test:integration:trade": "jest src/trade/trade.integration.spec.ts --runInBand --verbose",
    "test:integration:ledger": "jest --config jest-integration.config.ts src/ledger/ledger.integration.spec.ts --runInBand --verbose",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/mapped-types": "^2.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.0.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "nodemailer": "^8.0.7",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^3.0.9",
    "@types/supertest": "^7.2.0",
    "jest": "^29.5.0",
    "prisma": "^5.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
