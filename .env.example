# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="your-postgres-url"

# Integration tests use a SEPARATE database — copy this file to .env.test:
#   cp .env .env.test
#   # change the database name to jewelryflow_test (not jewelryflow_dev)
# Then run: npm run db:test:setup

# ── Auth ───────────────────────────────────────────────────────────────────────
# JWT Configuration (for reference — currently set in code)
JWT_SECRET=<generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
# JWT_ACCESS_EXPIRY=15m
# JWT_REFRESH_EXPIRY=7d

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS — comma-separated list of allowed frontend origins ───────────────────
# Local install default: http://localhost:5173
# Server deployment: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# ── Email (SMTP) — for OTP verification emails ───────────────────────────────
# Gmail example: use an App Password (not your regular password)
# See: https://support.google.com/accounts/answer/185833
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="\"JewelryFlow\" <your-email@gmail.com>"
